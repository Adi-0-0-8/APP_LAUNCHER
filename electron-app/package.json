{
  "name": "launcher-app",
  "version": "1.0.1",
  "description": "App Launcher - Quick access to your favorite apps",
  "main": "main.js",
  "author": "Aditya U",
  "copyright": "Copyright © 2026 Aditya U",
  "repository": {
    "type": "git",
    "url": "https://github.com/Adi-0-0-8/APP_LAUNCHER"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable --config",
    "build:dir": "electron-builder --win --dir",
    "release": "electron-builder --win --publish always"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.launcher.app",
    "productName": "AppLauncher",
    "icon": "assets/icon.ico",
    "publish": [
      {
        "provider": "github",
        "owner": "Adi-0-0-8",
        "repo": "APP_LAUNCHER"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      ".env",
      "renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "publisherName": "Aditya U"
    },
    "portable": {
      "artifactName": "AppLauncher-Portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "AppLauncher-Setup.exe",
      "include": "installer.nsh"
    },
    "compression": "maximum",
    "asar": true,
    "asarUnpack": [
      ".env"
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false
  }
}
